{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 ProPaint - Build & Run Debug",
            "type": "dart",
            "request": "launch",
            "preLaunchTask": "build:app:debug",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "name": "⚡ ProPaint - Build Debug (キャッシュ使用)",
            "type": "dart",
            "request": "launch",
            "preLaunchTask": "build:app:debug-cache",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "name": "📦 ProPaint - Build Release",
            "type": "dart",
            "request": "launch",
            "preLaunchTask": "build:app:release",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "name": "Flutter UI Debug",
            "cwd": "propaint_flutter",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "Flutter UI Profile",
            "cwd": "propaint_flutter",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "Flutter UI Release",
            "cwd": "propaint_flutter",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}