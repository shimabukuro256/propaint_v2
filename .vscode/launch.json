{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 ProPaint - Build & Run Debug",
            "type": "shell",
            "request": "launch",
            "command": "./gradlew",
            "args": [
                "clean",
                ":app:installDebug"
            ],
            "group": {
                "kind": "debug",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "name": "📦 ProPaint - Build Release",
            "type": "shell",
            "request": "launch",
            "command": "./gradlew",
            "args": [
                "clean",
                ":app:assembleRelease"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "name": "⚡ ProPaint - Build Debug (キャッシュ使用)",
            "type": "shell",
            "request": "launch",
            "command": "./gradlew",
            "args": [
                ":app:installDebug"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "name": "Flutter UI Debug",
            "cwd": "propaint_flutter",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "Flutter UI Profile",
            "cwd": "propaint_flutter",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "Flutter UI Release",
            "cwd": "propaint_flutter",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}